page {
  background-color: #F2F4F7;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ====== 顶部渐变英雄区 ====== */
.hero {
  background: linear-gradient(135deg, #165DFF 0%, #3C7EFF 50%, #6E9EFF 100%);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.hero::after {
  content: "";
  position: absolute;
  bottom: -80rpx;
  left: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}

.hero-content {
  padding: 60rpx 40rpx 80rpx;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  display: block;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

.hero-wave {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 40rpx;
  background: #F2F4F7;
  border-radius: 40rpx 40rpx 0 0;
}

/* ====== 主内容区 ====== */
.main-content {
  padding: 0 30rpx 40rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

/* ====== 通用卡片 ====== */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ====== 输入卡 ====== */
.input-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.card-icon-label {
  font-size: 36rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #F7F8FA;
  border: 2rpx solid #E5E6EB;
  border-radius: 16rpx;
  padding: 0 28rpx;
  transition: border-color 0.2s;
}

.input-wrap:focus-within {
  border-color: #165DFF;
  background: #FFFFFF;
}

.num-input {
  flex: 1;
  padding: 26rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
  background: transparent;
  border: none;
  outline: none;
  height: auto;
  min-height: auto;
}

.num-input::placeholder {
  color: #C9CDD4;
  font-weight: 400;
}

.input-unit {
  font-size: 28rpx;
  color: #8F959E;
  margin-left: 12rpx;
}

/* ====== 按钮区域 ====== */
.button-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  border: none;
  text-align: left;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-btn::after {
  border: none;
}

.btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.photo-btn {
  background: linear-gradient(135deg, #165DFF, #3C7EFF);
  color: #FFFFFF;
}

.upload-btn {
  background: linear-gradient(135deg, #36D399, #4ADE80);
  color: #FFFFFF;
}

.btn-icon {
  font-size: 48rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.btn-icon-text {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

.btn-desc {
  font-size: 22rpx;
  opacity: 0.75;
}

/* ====== 结果区域 ====== */
.result-section {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 结果卡片 */
.result-card {
  padding: 36rpx 32rpx;
  border-left: 8rpx solid #36D399;
}

.result-card.error {
  border-left-color: #F87272;
}

.result-status-bar {
  margin-bottom: 28rpx;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.success-badge {
  background: #E8F8F0;
  color: #36D399;
}

.error-badge {
  background: #FEF0F0;
  color: #F87272;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 56rpx;
  font-weight: 700;
}

.stat-num.total { color: #165DFF; }
.stat-num.actual { color: #36D399; }
.stat-num.absent { color: #F87272; }

.stat-label {
  font-size: 26rpx;
  color: #8F959E;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: #E5E6EB;
}

/* 到勤率进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F2F4F7;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #F2F4F7;
  border-radius: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #36D399, #4ADE80);
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.progress-label {
  font-size: 26rpx;
  color: #36D399;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

/* 图片卡片 */
.image-card {
  padding: 28rpx;
  margin-bottom: 12rpx;
}

.image-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.image-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
}

.preview-tip {
  font-size: 26rpx;
  color: #165DFF;
  font-weight: 500;
  padding: 6rpx 12rpx;
}

.result-image {
  width: 100%;
  border-radius: 14rpx;
  background: #F7F8FA;
}

.image-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.ghost-btn {
  background: #F7F8FA;
  color: #4E5969;
  border: 2rpx solid #E5E6EB;
  border-radius: 16rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.ghost-btn::after {
  border: none;
}
