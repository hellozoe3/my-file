page {
  background-color: #F2F4F7;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 70vh;
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  background: #F7F8FA;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8F959E;
}

/* ====== 有数据布局 ====== */
.has-data {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ====== 顶部统计栏 ====== */
.summary-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #165DFF, #3C7EFF);
  margin: 24rpx 30rpx;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(22, 93, 255, 0.25);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.summary-divider {
  width: 2rpx;
  height: 44rpx;
  background: rgba(255, 255, 255, 0.25);
}

/* ====== 工具栏 ====== */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 20rpx;
}

.toolbar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D2129;
}

.clear-all-btn {
  font-size: 26rpx;
  color: #8F959E;
  background: #F2F4F7;
  border: 2rpx solid #E5E6EB;
  border-radius: 30rpx;
  padding: 8rpx 24rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  line-height: 1.4;
}

.clear-all-btn::after {
  border: none;
}

/* ====== 记录列表 ====== */
.record-scroll {
  flex: 1;
  padding: 0 30rpx 30rpx;
  box-sizing: border-box;
}

/* ====== 记录卡片 ====== */
.record-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.record-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #165DFF, #36D399);
  border-radius: 0 6rpx 6rpx 0;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.record-time-icon {
  font-size: 28rpx;
}

.record-time {
  font-size: 26rpx;
  color: #4E5969;
  font-weight: 500;
}

.delete-btn {
  font-size: 24rpx;
  color: #F87272;
  background: #FEF0F0;
  border: none;
  border-radius: 30rpx;
  padding: 8rpx 22rpx;
  line-height: 1.4;
  min-width: auto;
}

.delete-btn::after {
  border: none;
}

.delete-hover {
  opacity: 0.6;
}

/* ====== 统计标签 ====== */
.record-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-total {
  background: #E8F0FE;
  color: #165DFF;
}

.tag-actual {
  background: #E8F8F0;
  color: #36D399;
}

.tag-absent {
  background: #FEF0F0;
  color: #F87272;
}

/* ====== 缩略图 ====== */
.record-image-wrap {
  position: relative;
  border-radius: 14rpx;
  overflow: hidden;
  margin-left: 12rpx;
}

.record-image {
  width: 100%;
  height: 240rpx;
  display: block;
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.4));
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 10rpx;
}

.image-overlay-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}